# ─────────────────────────────────────────────────────────────────────────────
# PrumoCanteiro — Variáveis para rodar LOCAL
# Copie este arquivo para .env.local e preencha com os dados do seu Supabase
#
# Como obter as variáveis:
#   1. Acesse https://supabase.com/dashboard e crie um projeto (grátis)
#   2. Vá em Settings → API → copie "Project URL" e "anon public"
#   3. Vá em Settings → Database → copie as connection strings
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase Auth ──────────────────────────────────────────────────────────────
# Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co

# Settings → API → anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Banco de dados Supabase (PostgreSQL) ───────────────────────────────────────
# Settings → Database → Connection string → Mode: Transaction (porta 6543)
DATABASE_URL=postgresql://postgres.SEU-PROJETO:SUA-SENHA@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# Settings → Database → Connection string → Mode: Session (porta 5432)
DIRECT_URL=postgresql://postgres.SEU-PROJETO:SUA-SENHA@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# ── App ────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3001
