# ── PrumoCanteiro — Variáveis de Ambiente ──────────────────────────────────
# Copie para .env e preencha os valores antes de rodar
# NUNCA commite o arquivo .env

# ── Banco de dados (SQLite) ────────────────────────────────────────────────
# Local:      file:./prisma/dev.db
# Docker:     file:/app/data/prumo.db  (volume persistente)
DATABASE_URL="file:./prisma/dev.db"

# ── Autenticação (session HMAC — OBRIGATÓRIO em produção) ─────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET="troque-por-uma-string-aleatoria-de-64-chars!"

# ── URL pública do app ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://prumocanteiro.com.br"

# ── IA — Predição de Atrasos (opcional) ───────────────────────────────────
# Gemini Free: https://aistudio.google.com/apikey
# Mesmo GEMINI_API_KEY do JurisMonitor pode ser reaproveitado
GEMINI_API_KEY=""

# ── STT — Diário por Áudio (opcional) ─────────────────────────────────────
# OpenAI Whisper API — sem key, feature retorna placeholder
OPENAI_API_KEY=""

# ── WhatsApp — Robô de Cobrança (opcional) ────────────────────────────────
# Evolution API v2 ou Z-API. Sem config, a cobrança é logada mas não enviada.
# Evolution API: URL = https://seu-servidor/api, KEY = Bearer token, INSTANCE = nome da instância
# Z-API:         URL = https://api.z-api.io/instances/INSTANCE_ID, KEY = token client-token
WHATSAPP_API_URL=""
WHATSAPP_API_KEY=""
WHATSAPP_INSTANCE=""

# ── Cron — Autenticação do endpoint de cobrança ────────────────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Chame: GET /api/cron/cobranca com header x-cron-secret: <valor>
CRON_SECRET=""
