// PrumoCanteiro — Prisma Schema
// Multi-tenant: cada Empresa é isolada por empresaId em todas as tabelas.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────── SaaS Layer ───────────────────────────

model Plano {
  id             String       @id @default(cuid())
  nome           String
  preco          Decimal      @db.Decimal(10, 2)
  limiteObras    Int?
  limiteUsuarios Int?
  recursos       String[]
  destaque       Boolean      @default(false)
  assinaturas    Assinatura[]
  criadoEm      DateTime     @default(now())
  atualizadoEm  DateTime     @updatedAt

  @@map("planos")
}

enum StatusAssinatura {
  ativo
  trial
  inadimplente
  cancelado
}

model Assinatura {
  id              String           @id @default(cuid())
  empresa         Empresa          @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  empresaId       String           @unique
  plano           Plano            @relation(fields: [planoId], references: [id])
  planoId         String
  status          StatusAssinatura @default(trial)
  desde           DateTime         @default(now())
  proximaCobranca DateTime?
  criadoEm       DateTime         @default(now())
  atualizadoEm   DateTime         @updatedAt

  @@map("assinaturas")
}

// ─────────────────────────── Empresa & Usuários ───────────────────

model Empresa {
  id               String                @id @default(cuid())
  nome             String
  assinatura       Assinatura?
  usuarios         Usuario[]
  terrenos         Terreno[]
  obras            Obra[]
  funcionarios     Funcionario[]
  notas            NotaFiscal[]
  pagamentos       PagamentoFuncionario[]
  vendas           Venda[]
  documentos       Documento[]
  diario           DiarioObra[]
  criadoEm        DateTime              @default(now())
  atualizadoEm    DateTime              @updatedAt

  @@map("empresas")
}

model Usuario {
  id           String   @id
  empresa      Empresa  @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  empresaId    String
  nome         String
  email        String   @unique
  superAdmin   Boolean  @default(false)
  criadoEm    DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@map("usuarios")
}

// ─────────────────────────── Terrenos ─────────────────────────────

enum StatusTerreno {
  disponivel
  em_obra    @map("em-obra")
  vendido
}

model Terreno {
  id          String        @id @default(cuid())
  empresa     Empresa       @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  empresaId   String
  nome        String
  numero      String?
  endereco    String?
  cidade      String
  area        Decimal       @db.Decimal(10, 2)
  status      StatusTerreno @default(disponivel)
  aquisicao   DateTime?
  valorCompra Decimal?      @db.Decimal(14, 2)
  obras       Obra[]
  vendas      Venda[]
  documentos  Documento[]
  criadoEm   DateTime      @default(now())
  atualizadoEm DateTime     @updatedAt

  @@index([empresaId])
  @@map("terrenos")
}

// ─────────────────────────── Obras ────────────────────────────────

enum StatusObra {
  planejamento
  em_andamento @map("em-andamento")
  parada
  concluida
}

model Obra {
  id           String                 @id @default(cuid())
  empresa      Empresa                @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  empresaId    String
  terreno      Terreno                @relation(fields: [terrenoId], references: [id])
  terrenoId    String
  nome         String
  status       StatusObra             @default(planejamento)
  orcamento    Decimal                @db.Decimal(14, 2)
  inicio       DateTime?
  prazo        DateTime?
  progresso    Int                    @default(0)
  responsavel  String?
  alocacoes    AlocacaoFuncionario[]
  notas        NotaFiscal[]
  pagamentos   PagamentoFuncionario[]
  documentos   Documento[]
  diario       DiarioObra[]
  criadoEm    DateTime               @default(now())
  atualizadoEm DateTime               @updatedAt

  @@index([empresaId])
  @@map("obras")
}

// ─────────────────────────── Funcionários ─────────────────────────

enum StatusFuncionario {
  ativo
  inativo
}

model Funcionario {
  id           String                 @id @default(cuid())
  empresa      Empresa                @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  empresaId    String
  nome         String
  cargo        String?
  cpf          String?
  telefone     String?
  email        String?
  salario      Decimal?               @db.Decimal(10, 2)
  admissao     DateTime?
  status       StatusFuncionario      @default(ativo)
  alocacoes    AlocacaoFuncionario[]
  pagamentos   PagamentoFuncionario[]
  notas        NotaFiscal[]
  criadoEm    DateTime               @default(now())
  atualizadoEm DateTime               @updatedAt

  @@index([empresaId])
  @@map("funcionarios")
}

model AlocacaoFuncionario {
  id            String      @id @default(cuid())
  funcionario   Funcionario @relation(fields: [funcionarioId], references: [id], onDelete: Cascade)
  funcionarioId String
  obra          Obra        @relation(fields: [obraId], references: [id], onDelete: Cascade)
  obraId        String
  cargo         String?
  inicio        DateTime?
  fim           DateTime?
  criadoEm     DateTime    @default(now())

  @@index([funcionarioId])
  @@index([obraId])
  @@map("alocacoes_funcionarios")
}

model PagamentoFuncionario {
  id            String      @id @default(cuid())
  empresa       Empresa     @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  empresaId     String
  funcionario   Funcionario @relation(fields: [funcionarioId], references: [id])
  funcionarioId String
  obra          Obra?       @relation(fields: [obraId], references: [id])
  obraId        String?
  valor         Decimal     @db.Decimal(14, 2)
  descricao     String?
  pagoEm        DateTime?
  criadoEm     DateTime    @default(now())

  @@index([empresaId])
  @@index([funcionarioId])
  @@map("pagamentos_funcionarios")
}

// ─────────────────────────── Notas Fiscais ────────────────────────

enum CategoriaNotaFiscal {
  material
  mao_obra     @map("mao-obra")
  servicos
  equipamentos
  outros
}

enum StatusNotaFiscal {
  pendente
  em_revisao   @map("em-revisao")
  confirmada
  cancelada
}

model NotaFiscal {
  id            String              @id @default(cuid())
  empresa       Empresa             @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  empresaId     String
  obra          Obra                @relation(fields: [obraId], references: [id], onDelete: Cascade)
  obraId        String
  funcionario   Funcionario?        @relation(fields: [funcionarioId], references: [id])
  funcionarioId String?
  fornecedor    String?
  numero        String?
  categoria     CategoriaNotaFiscal @default(material)
  valor         Decimal             @db.Decimal(14, 2)
  emitidaEm    DateTime?
  status        StatusNotaFiscal    @default(pendente)
  descricao     String?
  arquivoUrl    String?
  criadoEm     DateTime            @default(now())
  atualizadoEm DateTime             @updatedAt

  @@index([empresaId])
  @@index([obraId])
  @@map("notas_fiscais")
}

// ─────────────────────────── Vendas de Terrenos ───────────────────

model Venda {
  id                 String    @id @default(cuid())
  empresa            Empresa   @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  empresaId          String
  terreno            Terreno   @relation(fields: [terrenoId], references: [id])
  terrenoId          String
  nomeComprador      String
  cpfCnpjComprador   String?
  telefoneComprador   String?
  emailComprador     String?
  valorTotal         Decimal   @db.Decimal(14, 2)
  entrada            Decimal   @default(0) @db.Decimal(14, 2)
  numeroParcelas     Int       @default(1)
  diaVencimento      Int       @default(5)
  dataContrato       DateTime?
  observacoes        String?
  parcelas           Parcela[]
  documentos         Documento[]
  criadoEm          DateTime  @default(now())
  atualizadoEm      DateTime  @updatedAt

  @@index([empresaId])
  @@map("vendas")
}

model Parcela {
  id         String    @id @default(cuid())
  venda      Venda     @relation(fields: [vendaId], references: [id], onDelete: Cascade)
  vendaId    String
  numero     Int
  vencimento DateTime?
  valor      Decimal   @db.Decimal(14, 2)
  status     String    @default("aberta")
  pagoEm     DateTime?
  criadoEm  DateTime  @default(now())
  atualizadoEm DateTime @updatedAt

  @@index([vendaId])
  @@map("parcelas")
}

// ─────────────────────────── Documentos ───────────────────────────

enum OwnerTypeDocumento {
  obra
  venda
  terreno
}

model Documento {
  id        String             @id @default(cuid())
  empresa   Empresa            @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  empresaId String
  ownerType OwnerTypeDocumento
  obraId    String?
  obra      Obra?              @relation(fields: [obraId], references: [id], onDelete: Cascade)
  vendaId   String?
  venda     Venda?             @relation(fields: [vendaId], references: [id], onDelete: Cascade)
  terrenoId String?
  terreno   Terreno?           @relation(fields: [terrenoId], references: [id], onDelete: Cascade)
  nome      String
  tipo      String
  tamanho   Int
  url       String
  criadoEm DateTime           @default(now())

  @@index([empresaId])
  @@map("documentos")
}

// ─────────────────────────── Diário de Obra ───────────────────────

model DiarioObra {
  id             String   @id @default(cuid())
  empresa        Empresa  @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  empresaId      String
  obra           Obra     @relation(fields: [obraId], references: [id], onDelete: Cascade)
  obraId         String
  data           DateTime?
  conteudo       String
  autor          String?
  clima          String?
  equipePresente Int?
  criadoEm      DateTime @default(now())

  @@index([obraId])
  @@map("diario_obras")
}
