// PrumoCanteiro — Prisma Schema (SQLite local / PostgreSQL produção)
// Multi-tenant: cada Empresa é isolada por empresaId em todas as tabelas.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// ─────────────────────────── SaaS Layer ───────────────────────────

model Plano {
  id             String       @id @default(cuid())
  nome           String
  preco          Decimal
  limiteObras    Int?
  limiteUsuarios Int?
  recursos       String       @default("[]")
  destaque       Boolean      @default(false)
  assinaturas    Assinatura[]
  criadoEm      DateTime     @default(now())
  atualizadoEm  DateTime     @updatedAt

  @@map("planos")
}

model Assinatura {
  id              String   @id @default(cuid())
  empresa         Empresa  @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  empresaId       String   @unique
  plano           Plano    @relation(fields: [planoId], references: [id])
  planoId         String
  status          String   @default("trial")
  desde           DateTime @default(now())
  proximaCobranca DateTime?
  criadoEm       DateTime @default(now())
  atualizadoEm   DateTime @updatedAt

  @@map("assinaturas")
}

// ─────────────────────────── Empresa & Usuários ───────────────────

model Empresa {
  id               String                 @id @default(cuid())
  nome             String
  assinatura       Assinatura?
  usuarios         Usuario[]
  terrenos         Terreno[]
  obras            Obra[]
  funcionarios     Funcionario[]
  notas            NotaFiscal[]
  pagamentos       PagamentoFuncionario[]
  vendas           Venda[]
  documentos       Documento[]
  diario           DiarioObra[]
  criadoEm        DateTime               @default(now())
  atualizadoEm    DateTime               @updatedAt

  @@map("empresas")
}

model Usuario {
  id            String   @id @default(cuid())
  empresa       Empresa  @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  empresaId     String
  nome          String
  email         String   @unique
  passwordHash  String?
  superAdmin    Boolean  @default(false)
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@map("usuarios")
}

// ─────────────────────────── Terrenos ─────────────────────────────

model Terreno {
  id          String     @id @default(cuid())
  empresa     Empresa    @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  empresaId   String
  nome        String
  numero      String?
  endereco    String?
  cidade      String
  area        Decimal
  status      String     @default("disponivel")
  aquisicao   DateTime?
  valorCompra Decimal?
  obras       Obra[]
  vendas      Venda[]
  documentos  Documento[]
  criadoEm   DateTime   @default(now())
  atualizadoEm DateTime  @updatedAt

  @@index([empresaId])
  @@map("terrenos")
}

// ─────────────────────────── Obras ────────────────────────────────

model Obra {
  id           String                 @id @default(cuid())
  empresa      Empresa                @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  empresaId    String
  terreno      Terreno?               @relation(fields: [terrenoId], references: [id])
  terrenoId    String?
  nome         String
  status       String                 @default("planejamento")
  orcamento    Decimal
  inicio       DateTime?
  prazo        DateTime?
  progresso    Int                    @default(0)
  responsavel  String?
  alocacoes    AlocacaoFuncionario[]
  notas        NotaFiscal[]
  pagamentos   PagamentoFuncionario[]
  documentos   Documento[]
  diario       DiarioObra[]
  criadoEm    DateTime               @default(now())
  atualizadoEm DateTime               @updatedAt

  @@index([empresaId])
  @@map("obras")
}

// ─────────────────────────── Funcionários ─────────────────────────

model Funcionario {
  id           String                 @id @default(cuid())
  empresa      Empresa                @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  empresaId    String
  nome         String
  cargo        String?
  cpf          String?
  telefone     String?
  email        String?
  salario      Decimal?
  admissao     DateTime?
  status       String                 @default("ativo")
  alocacoes    AlocacaoFuncionario[]
  pagamentos   PagamentoFuncionario[]
  notas        NotaFiscal[]
  criadoEm    DateTime               @default(now())
  atualizadoEm DateTime               @updatedAt

  @@index([empresaId])
  @@map("funcionarios")
}

model AlocacaoFuncionario {
  id            String      @id @default(cuid())
  funcionario   Funcionario @relation(fields: [funcionarioId], references: [id], onDelete: Cascade)
  funcionarioId String
  obra          Obra        @relation(fields: [obraId], references: [id], onDelete: Cascade)
  obraId        String
  cargo         String?
  inicio        DateTime?
  fim           DateTime?
  criadoEm     DateTime    @default(now())

  @@index([funcionarioId])
  @@index([obraId])
  @@map("alocacoes_funcionarios")
}

model PagamentoFuncionario {
  id            String      @id @default(cuid())
  empresa       Empresa     @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  empresaId     String
  funcionario   Funcionario @relation(fields: [funcionarioId], references: [id])
  funcionarioId String
  obra          Obra?       @relation(fields: [obraId], references: [id])
  obraId        String?
  valor         Decimal
  descricao     String?
  pagoEm        DateTime?
  criadoEm     DateTime    @default(now())

  @@index([empresaId])
  @@index([funcionarioId])
  @@map("pagamentos_funcionarios")
}

// ─────────────────────────── Notas Fiscais ────────────────────────

model NotaFiscal {
  id            String      @id @default(cuid())
  empresa       Empresa     @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  empresaId     String
  obra          Obra        @relation(fields: [obraId], references: [id], onDelete: Cascade)
  obraId        String
  funcionario   Funcionario? @relation(fields: [funcionarioId], references: [id])
  funcionarioId String?
  fornecedor    String?
  numero        String?
  categoria     String      @default("material")
  valor         Decimal
  emitidaEm    DateTime?
  status        String      @default("pendente")
  descricao     String?
  arquivoUrl    String?
  criadoEm     DateTime    @default(now())
  atualizadoEm DateTime     @updatedAt

  @@index([empresaId])
  @@index([obraId])
  @@map("notas_fiscais")
}

// ─────────────────────────── Vendas de Terrenos ───────────────────

model Venda {
  id                 String      @id @default(cuid())
  empresa            Empresa     @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  empresaId          String
  terreno            Terreno     @relation(fields: [terrenoId], references: [id])
  terrenoId          String
  nomeComprador      String
  cpfCnpjComprador   String?
  telefoneComprador  String?
  emailComprador     String?
  valorTotal         Decimal
  entrada            Decimal     @default(0)
  numeroParcelas     Int         @default(1)
  diaVencimento      Int         @default(5)
  dataContrato       DateTime?
  observacoes        String?
  parcelas           Parcela[]
  documentos         Documento[]
  criadoEm          DateTime    @default(now())
  atualizadoEm      DateTime    @updatedAt

  @@index([empresaId])
  @@map("vendas")
}

model Parcela {
  id         String    @id @default(cuid())
  venda      Venda     @relation(fields: [vendaId], references: [id], onDelete: Cascade)
  vendaId    String
  numero     Int
  vencimento DateTime?
  valor      Decimal
  status     String    @default("aberta")
  pagoEm     DateTime?
  criadoEm  DateTime  @default(now())
  atualizadoEm DateTime @updatedAt

  @@index([vendaId])
  @@map("parcelas")
}

// ─────────────────────────── Documentos ───────────────────────────

model Documento {
  id        String    @id @default(cuid())
  empresa   Empresa   @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  empresaId String
  ownerType String
  obraId    String?
  obra      Obra?     @relation(fields: [obraId], references: [id], onDelete: Cascade)
  vendaId   String?
  venda     Venda?    @relation(fields: [vendaId], references: [id], onDelete: Cascade)
  terrenoId String?
  terreno   Terreno?  @relation(fields: [terrenoId], references: [id], onDelete: Cascade)
  nome      String
  tipo      String
  tamanho   Int
  url       String
  criadoEm DateTime  @default(now())

  @@index([empresaId])
  @@map("documentos")
}

// ─────────────────────────── Diário de Obra ───────────────────────

model DiarioObra {
  id             String   @id @default(cuid())
  empresa        Empresa  @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  empresaId      String
  obra           Obra     @relation(fields: [obraId], references: [id], onDelete: Cascade)
  obraId         String
  data           DateTime?
  conteudo       String
  fotoUrl        String?
  autor          String?
  clima          String?
  equipePresente Int?
  criadoEm      DateTime @default(now())

  @@index([obraId])
  @@map("diario_obras")
}

// ─────────────────────────── Features Avançadas (append-only) ────────
// IDs referenciam models existentes mas sem @relation para não tocar neles

model QrCodeInsumo {
  id           String   @id @default(cuid())
  empresaId    String
  codigo       String   @unique
  nome         String
  tipo         String   @default("insumo")
  descricao    String?
  obraId       String?
  qrImageUrl   String?
  ativo        Boolean  @default(true)
  criadoEm    DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@index([empresaId])
  @@map("qrcodes_insumos")
}

model PortalClienteToken {
  id        String    @id @default(cuid())
  empresaId String
  nome      String
  tokenHash String    @unique
  ativo     Boolean   @default(true)
  expiraEm  DateTime?
  ultimoUso DateTime?
  criadoEm DateTime  @default(now())

  @@index([empresaId])
  @@map("portal_cliente_tokens")
}

model PredicaoAtraso {
  id            String   @id @default(cuid())
  empresaId     String
  obraId        String
  riscoPct      Int      @default(0)
  diasAtraso    Int      @default(0)
  fatores       String   @default("[]")
  recomendacoes String   @default("[]")
  modeloUsado   String   @default("gemini")
  criadoEm     DateTime @default(now())

  @@index([obraId])
  @@map("predicoes_atraso")
}

model TranscricaoAudio {
  id          String   @id @default(cuid())
  empresaId   String
  obraId      String
  diarioId    String?
  audioUrl    String
  transcricao String
  durSeg      Int?
  status      String   @default("processado")
  criadoEm   DateTime @default(now())

  @@index([obraId])
  @@map("transcricoes_audio")
}

model CotacaoInsumo {
  id              String   @id @default(cuid())
  empresaId       String
  obraId          String?
  notaId          String?
  nome            String
  pdfUrl          String?
  insumos         String   @default("[]")
  webhookUrl      String?
  webhookStatus   String   @default("pendente")
  webhookResposta String?
  criadoEm       DateTime @default(now())
  atualizadoEm   DateTime @updatedAt

  @@index([empresaId])
  @@map("cotacoes_insumos")
}

model MedicaoFoto {
  id         String   @id @default(cuid())
  empresaId  String
  obraId     String
  fotoUrl    String
  etapa      String?
  metadata   String   @default("{}")
  analiseUrl String?
  status     String   @default("pendente")
  criadoEm  DateTime @default(now())

  @@index([obraId])
  @@map("medicoes_foto")
}

model RateioNFe {
  id           String   @id @default(cuid())
  empresaId    String
  notaId       String?
  chaveNFe     String?
  emitente     String?
  valorTotal   Decimal  @default(0)
  itens        String   @default("[]")
  regras       String   @default("[]")
  rateioResult String   @default("[]")
  criadoEm    DateTime @default(now())

  @@index([empresaId])
  @@map("rateio_nfe")
}

// ─────────────────────────── Checklists ──────────────────────────────────
// Polimórfico: obraId/terrenoId sem @relation (append-only, não toca tabelas existentes)

model ChecklistTemplate {
  id       String                  @id @default(cuid())
  tipo     String                  @unique
  nome     String
  ordem    Int                     @default(0)
  itens    ChecklistTemplateItem[]
  criadoEm DateTime               @default(now())

  @@map("checklist_templates")
}

model ChecklistTemplateItem {
  id          String            @id @default(cuid())
  template    ChecklistTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  templateId  String
  descricao   String
  obrigatorio Boolean           @default(true)
  ordem       Int               @default(0)
  criadoEm   DateTime          @default(now())

  @@index([templateId])
  @@map("checklist_template_itens")
}

model Checklist {
  id          String          @id @default(cuid())
  empresaId   String
  ownerType   String
  obraId      String?
  terrenoId   String?
  templateId  String
  fase        String
  status      String          @default("ativo")
  itens       ChecklistItem[]
  criadoEm   DateTime        @default(now())
  atualizadoEm DateTime      @updatedAt

  @@index([empresaId])
  @@index([obraId])
  @@index([terrenoId])
  @@map("checklists")
}

model ChecklistItem {
  id             String    @id @default(cuid())
  checklist      Checklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  checklistId    String
  templateItemId String
  descricao      String
  concluido      Boolean   @default(false)
  concluidoEm   DateTime?
  observacao     String?
  criadoEm      DateTime  @default(now())
  atualizadoEm  DateTime  @updatedAt

  @@index([checklistId])
  @@map("checklist_itens")
}

// ─────────────────────────── Garantia & Assistência Técnica ──────────────────
// Append-only: sem @relation nas tabelas existentes

model GarantiaComponente {
  id                String   @id @default(cuid())
  empresaId         String
  codigo            String
  nome              String
  prazoLegalMeses   Int
  prazoContratMeses Int
  marcoInicial      String   @default("entrega_chaves")
  baseLegal         String?
  ativo             Boolean  @default(true)
  criadoEm         DateTime @default(now())

  @@unique([empresaId, codigo])
  @@index([empresaId])
  @@map("garantia_componentes")
}

model ChamadoAssistencia {
  id                String    @id @default(cuid())
  empresaId         String
  vendaId           String
  componenteId      String
  descricao         String
  status            String    @default("aberto")
  dataEntregaChaves DateTime?
  parecerStatus     String?
  parecerTexto      String?
  parecerGeradoEm  DateTime?
  criadoEm         DateTime  @default(now())
  atualizadoEm     DateTime  @updatedAt

  @@index([empresaId])
  @@index([vendaId])
  @@map("chamados_assistencia")
}

// ─────────────────────────── Cobrança Automatizada ───────────────────────────

model CobrancaLog {
  id        String   @id @default(cuid())
  empresaId String
  parcelaId String
  tipo      String
  canal     String   @default("whatsapp")
  status    String   @default("pendente")
  payload   String?
  resposta  String?
  criadoEm DateTime @default(now())

  @@index([empresaId])
  @@index([parcelaId])
  @@map("cobranca_logs")
}
